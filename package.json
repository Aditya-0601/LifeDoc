    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.1",
    "pg": "^8.20.0",
    "sharp": "^0.32.6",
    "sqlite3": "^5.1.6",
    "tesseract.js": "^5.1.1",
    "uuid": "^9.0.1"
