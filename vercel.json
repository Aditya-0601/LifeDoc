{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://lifedoc-backend.onrender.com/api/$1"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "https://lifedoc-backend.onrender.com/uploads/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
