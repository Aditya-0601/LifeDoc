{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://lifedoc-backend.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://lifedoc-backend.onrender.com/uploads/:path*"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
